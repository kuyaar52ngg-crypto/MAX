# Supabase Auth (Settings -> API)
# Google login is configured in Supabase Dashboard -> Authentication -> Providers -> Google.
# Google Cloud redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
# Supabase app redirect URL: http://localhost:3000/auth/callback
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Prisma PostgreSQL connection string (Supabase -> Settings -> Database -> Connection Pooler)
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# Flask backend URL
NEXT_PUBLIC_API_URL=http://localhost:5000
