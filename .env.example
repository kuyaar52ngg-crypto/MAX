# Flask backend
# Railway sets PORT automatically. FLASK_PORT is used for local/VPS runs.
FLASK_PORT=5000
FLASK_DEBUG=0

# Comma-separated frontend origins allowed by Flask CORS.
# Local dev example: http://localhost:3000
# VPS example: http://YOUR_SERVER_IP:3000
FRONTEND_URL=http://localhost:3000
FRONTEND_ORIGINS=

# Frontend should use frontend/.env.local (see frontend/.env.example)

# Ollama Cloud (server-side only, used by Next.js /api/ai/generate proxy).
# NEVER commit a real key — keep the value in .env (which is gitignored).
OLLAMA_API_KEY=
OLLAMA_MODEL=gemma3:27b-cloud
