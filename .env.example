# GREEN-API instance credentials
# Get them at https://green-api.com/
ID_INSTANCE=your_instance_id
API_TOKEN_INSTANCE=your_api_token
GREEN_API_URL=https://api.green-api.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Prisma — PostgreSQL connection string (from Supabase → Settings → Database)
DATABASE_URL=postgresql://postgres.your-password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
