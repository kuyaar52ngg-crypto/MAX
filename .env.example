# Flask backend
# Railway sets PORT automatically. FLASK_PORT is used for local/VPS runs.
FLASK_PORT=5000
FLASK_DEBUG=0

# Comma-separated frontend origins allowed by Flask CORS.
# Local dev example: http://localhost:3000
# VPS example: http://YOUR_SERVER_IP:3000
FRONTEND_URL=http://localhost:3000
FRONTEND_ORIGINS=

# Frontend should use frontend/.env.local (see frontend/.env.example)

# Ollama Cloud (server-side only, used by Next.js /api/ai/generate proxy).
# NEVER commit a real key — keep the value in .env (which is gitignored).
OLLAMA_API_KEY=
OLLAMA_MODEL=gemma3:27b-cloud

# Notification email relay (Flask Notification_Dispatcher → Next.js).
# Flask sends X-Notification-Relay-Secret with this same value.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NOTIFICATION_RELAY_SECRET=

# SMTP configuration for the Next.js email-relay endpoint.
# All five fields are required for email delivery to work; if any is
# missing the relay returns 503 and Flask records a dispatch_error.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Optional: force TLS. When unset, port 465 implies secure=true and
# any other port implies STARTTLS (secure=false).
# SMTP_SECURE=false
