# Supabase Auth (Settings -> API)
# Google login is configured in Supabase Dashboard -> Authentication -> Providers -> Google.
# Google Cloud redirect URI: https://<project-ref>.supabase.co/auth/v1/callback
# Supabase app redirect URL: http://localhost:3000/auth/callback
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Prisma PostgreSQL connection string (Supabase -> Settings -> Database -> Connection Pooler)
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# Flask backend URL
NEXT_PUBLIC_API_URL=http://localhost:5000

# Ollama Cloud (server-side only, used by /api/ai/generate proxy).
# DO NOT prefix with NEXT_PUBLIC_ — the key must never reach the browser.
# Put the real value in frontend/.env.local (gitignored).
OLLAMA_API_KEY=
OLLAMA_MODEL=gemma3:27b-cloud

# Encryption key for GreenInstance api_token (AES-256-GCM)
# Must be exactly 32 bytes, base64 encoded.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
INSTANCE_ENCRYPTION_KEY=

# Notification email relay (Flask Notification_Dispatcher → Next.js).
# Flask must send the same value in the X-Notification-Relay-Secret header.
NOTIFICATION_RELAY_SECRET=

# SMTP configuration for /api/notifications/email-relay.
# All five fields are required; if any is missing the relay returns 503.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Optional: force TLS. When unset, port 465 implies secure=true and
# any other port implies STARTTLS (secure=false).
# SMTP_SECURE=false
